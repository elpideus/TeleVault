# ==============================================================================
# FRONTEND
# ==============================================================================

# TCP port that the frontend is served on (nginx in Docker, Vite dev server locally).
FRONTEND_PORT=5173          # Optional. Default: 5173.

# ==============================================================================
# TELEGRAM
# ==============================================================================

# Your Telegram application credentials.
# Create an app at https://my.telegram.org → "API development tools".
TELEGRAM_API_ID=            # Required. Integer.
TELEGRAM_API_HASH=          # Required. 32-character hex string.

# The Telegram user ID of the first admin account.
# This user is auto-promoted to "admin" on their first login.
# Find your ID by messaging @userinfobot on Telegram.
# If empty, no user is automatically made admin.
ADMIN_TELEGRAM_ID=          # Optional. Integer (64-bit). Example: 123456789

# ==============================================================================
# DATABASE (PostgreSQL)
# ==============================================================================

# Used by Docker Compose to initialise the PostgreSQL container on first run.
# DATABASE_URL is automatically built from these values (postgresql+asyncpg://<user>:<password>@db:5432/<db>).
POSTGRES_USER=televault          # Required.
POSTGRES_PASSWORD=change_this_password  # Required.
POSTGRES_DB=televault            # Required.

# Override the auto-generated connection string if you need a custom host, port, or driver.
DATABASE_URL=                    # Optional. Defaults to postgresql+asyncpg://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>.

# ==============================================================================
# SECURITY
# ==============================================================================

# Secret used to sign and verify JWT access tokens.
# Use a long random string (32+ characters). Rotating this logs out all users.
JWT_SECRET=                 # Required.

# Fernet symmetric key for encrypting Telegram session strings in the DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Changing this corrupts all stored sessions — all accounts must re-authenticate.
ENCRYPTION_KEY=             # Required. Base64-encoded 32-byte Fernet key.

# How long a refresh token stays valid before the user must log in again.
REFRESH_TOKEN_TTL_DAYS=90   # Optional. Default: 90.

# ==============================================================================
# APP CONFIG
# ==============================================================================

# Maximum allowed folder nesting depth. Root folders are at depth 0.
MAX_FOLDER_DEPTH=10         # Optional. Default: 10.

# Maximum allowed file size for folder icon uploads, in bytes (default 500 KB).
MAX_ICON_SIZE_BYTES=512000  # Optional. Default: 512000.

# Filesystem path where folder icon images are stored (relative to the backend working dir).
ICONS_DIR=./static/icons    # Optional. Default: ./static/icons.

# Chunk size for large file uploads, in bytes (default 90 MB).
# Cloudflare has a 100MB limit per request; keeping this under 95MB is recommended.
UPLOAD_CHUNK_SIZE=94371840  # Optional. Default: 94371840 (90 MB).

# JSON array of allowed CORS origins. Must include the frontend origin exactly.
# In Docker, this is typically http://localhost:<FRONTEND_PORT> (default: http://localhost:5173).
# Keep in sync with FRONTEND_PORT.
CORS_ORIGINS=["http://localhost:5173"]  # Required.

# Enable /playground debug UI and /api/v1/debug/* endpoints. Never true in production.
DEBUG_UI=false              # Optional. Default: false.

# ==============================================================================
# FRONTEND (build-time Vite variables — baked into the bundle at build)
# ==============================================================================

# Leave empty when running in Docker — nginx proxies /api/ to the backend.
# Set to a full URL (e.g. https://api.example.com) only when serving the
# frontend outside Docker without an nginx reverse proxy.
VITE_API_BASE_URL=

VITE_THEME=default
